---
interface Props {
  phoneNumber?: string;
  defaultMessage?: string;
}

const { 
  phoneNumber = "919814269633", 
  defaultMessage = "नमस्ते MM Car Care! मुझे अपनी कार के सर्विस और रिपेयर के बारे में पूछताछ करनी है।" 
} = Astro.props;

const urlEncodedMessage = encodeURIComponent(defaultMessage);
const whatsappUrl = `https://wa.me/${phoneNumber}?text=${urlEncodedMessage}`;
---

<a 
  href={whatsappUrl} 
  class="whatsapp-float-btn" 
  target="_blank" 
  rel="noopener noreferrer" 
  aria-label="Contact us on WhatsApp"
>
  <i class="fa-brands fa-whatsapp"></i>
  <span class="whatsapp-text" lang="hi-IN">मैं आपकी क्या मदद करूँ</span>
</a>

<style>
  .whatsapp-float-btn {
    position: fixed;
    bottom: var(--spacing-lg);
    right: var(--spacing-lg);
    background-color: #25d366;
    color: white;
    border-radius: 9999px; /* Pill shape as requested in the mockup image */
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    padding: 14px 28px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.4);
    z-index: 99;
    text-decoration: none;
    transition: transform var(--transition-speed) var(--transition-easing),
                background-color var(--transition-speed) var(--transition-easing);
    width: auto !important;
    height: auto !important;
  }

  .whatsapp-float-btn:hover {
    transform: scale(1.05);
    background-color: #128c7e;
  }

  .whatsapp-float-btn i {
    font-size: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .whatsapp-text {
    font-family: 'Noto Sans Devanagari', 'Poppins', sans-serif;
    font-size: 18px;
    font-weight: 700;
    white-space: nowrap !important;
    line-height: 1;
  }

  @media (max-width: 768px) {
    .whatsapp-float-btn {
      padding: 12px 20px;
      bottom: var(--spacing-md);
      right: var(--spacing-md);
      gap: var(--spacing-xxs);
      width: auto !important;
      height: auto !important;
    }
    .whatsapp-text {
      font-size: 16px;
    }
    .whatsapp-float-btn i {
      font-size: 24px;
    }
  }

  @media (max-width: 480px) {
    /* To prevent taking too much screen space on very small viewports, we make it slightly more compact */
    .whatsapp-float-btn {
      padding: 10px 16px;
      width: auto !important;
      height: auto !important;
    }
    .whatsapp-text {
      font-size: 14px;
    }
    .whatsapp-float-btn i {
      font-size: 22px;
    }
  }
</style>
