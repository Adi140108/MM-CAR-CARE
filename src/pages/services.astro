---

<Layout title={title} description={description}>
  <Navigation />

  <main>
    <!-- Page Title Header -->
    <section class="page-header">
      <div class="container header-inner">
        <div class="m-stripe page-stripe">
          <span class="blue-light"></span>
          <span class="blue-dark"></span>
          <span class="red"></span>
        </div>
        <span class="label-uppercase tracking-tag" lang="en">OUR EXPERTISE</span>
        <h1 class="display-lg page-title" lang="en">PRECISION SERVICES</h1>
        <p class="page-subtitle">
          हम आपकी कार को सर्वश्रेष्ठ सुरक्षा और यांत्रिक प्रदर्शन प्रदान करने के लिए प्रतिबद्ध हैं। नीचे हमारी प्रमुख सेवाओं की सूची दी गई है।
        </p>
      </div>
    </section>

    <!-- Services Detailed Showcase (Alternating Layout) -->
    <section class="services-list-section">
      {services.map((service, index) => (
        <div id={service.id} class={`service-block border-b ${index % 2 === 1 ? 'block-reverse' : ''}`}>
          <div class="container block-inner">
            <div class="service-image-area">
              <img src={service.image} alt={service.title} />
              <div class="m-stripe-overlay">
                <span class="blue-light"></span>
                <span class="blue-dark"></span>
                <span class="red"></span>
              </div>
            </div>
            <div class="service-details">
              <span class="label-uppercase category-tag" lang="en">SERVICE {index + 1}</span>
              <h2 class="display-md service-name" lang="en">{service.title}</h2>
              <h3 class="hindi-subtitle">{service.hindiTitle}</h3>
              
              <p class="body-md desc-text">{service.desc}</p>
              
              <ul class="features-list">
                {service.features.map(feat => (
                  <li><i class="fa-solid fa-circle-check"></i> <span>{feat}</span></li>
                ))}
              </ul>
              
              <div class="booking-price-row">
                <div class="price-badge">
                  <span class="caption" lang="en">ESTIMATED PRICE</span>
                  <strong class="price-val">{service.price}</strong>
                </div>
                <a 
                  href={`https://wa.me/919814269633?text=${encodeURIComponent(service.waMessage)}`} 
                  class="btn-primary booking-btn"
                  target="_blank"
                  rel="noopener noreferrer"
                  lang="en"
                >
                  BOOK SERVICE ON WHATSAPP
                </a>
              </div>
            </div>
          </div>
        </div>
      ))}
    </section>
  </main>

  <Footer />
  <WhatsAppFloat />
</Layout>

<style>
  /* Header styling */
  .page-header {
    background-color: var(--color-surface-soft);
    padding: var(--spacing-xxl) 0;
    border-bottom: 1px solid var(--color-hairline);
  }

  .header-inner {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .page-stripe {
    width: 80px;
    margin: 0 auto var(--spacing-md);
  }

  .tracking-tag {
    color: var(--color-m-blue-dark);
    display: block;
    margin-bottom: var(--spacing-xs);
  }

  .page-title {
    color: var(--color-primary);
    margin-bottom: var(--spacing-md);
  }

  .page-subtitle {
    font-size: 18px;
    font-weight: 300;
    line-height: 1.6;
    color: var(--color-body);
  }

  /* Service Blocks Alternating Layout */
  .service-block {
    padding: var(--spacing-section) 0;
    background-color: var(--color-canvas);
  }

  .service-block:nth-child(even) {
    background-color: var(--color-surface-soft);
  }

  .block-inner {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: var(--spacing-xxl);
    align-items: center;
  }

  .block-reverse .block-inner {
    grid-template-columns: 1.1fr 1fr;
  }

  .block-reverse .service-image-area {
    order: 2;
  }

  .service-image-area {
    position: relative;
    border: 1px solid var(--color-hairline);
  }

  .service-image-area img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
    background-color: #0d0d0d;
  }

  .service-image-area img[src$=".png"] {
    object-fit: contain;
    padding: var(--spacing-sm);
  }

  .m-stripe-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 4px;
    display: flex;
  }
  .m-stripe-overlay span { height: 100%; }
  .m-stripe-overlay .blue-light { width: 33%; background-color: var(--color-m-blue-light); }
  .m-stripe-overlay .blue-dark { width: 33%; background-color: var(--color-m-blue-dark); }
  .m-stripe-overlay .red { width: 34%; background-color: var(--color-m-red); }

  .service-details {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .category-tag {
    color: var(--color-m-red);
  }

  .service-name {
    color: var(--color-primary);
  }

  .hindi-subtitle {
    font-size: 20px;
    font-weight: 400;
    color: var(--color-body-strong);
