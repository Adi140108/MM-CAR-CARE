      "स्टीयरिंग व्हील में आने वाले कंपन का समाधान",
      "टायरों का समान वजन वितरण (Weight Distribution)",
      "हाईवे ड्राइविंग पर कार की स्थिरता में सुधार",
      "टायर की लाइफ और वियर पैटर्न चेक"
    ],
    price: "₹50 + ₹2 प्रति ग्राम",
    waMessage: "नमस्ते MM Car Care! मुझे अपनी कार की व्हील बैलेंसिंग सर्विस के लिए अपॉइंटमेंट बुक करना है।"
  },
  {
    id: "wheel-alignment",
    title: "3D WHEEL ALIGNMENT",
    hindiTitle: "3D व्हील अलाइनमेंट",
    image: "/wheel-alignment.png",
    desc: "सटीक 3D व्हील अलाइनमेंट द्वारा कार के स्टीयरिंग कंट्रोल को परफेक्ट किया जाता है, जिससे गाड़ी एक तरफ नहीं खिंचती और सीधे ट्रैक पर चलती है।",
    features: [
      "3D कम्प्यूटरीकृत व्हील अलाइनमेंट — ₹250",
      "कैम्बर, कास्टर और टो (Toe) एंगल्स का सटीक एडजस्टमेंट",
      "स्टीयरिंग व्हील सेंटरिंग और स्ट्रेट-लाइन स्टेबिलिटी",
      "सप्लीमेंट्री सस्पेंशन और स्टीयरिंग लिंकेज चेक",
      "टायर का असमान घिसना रोकने में मददगार"
    ],
    price: "₹250",
    waMessage: "नमस्ते MM Car Care! मुझे अपनी कार के 3D व्हील अलाइनमेंट के लिए अपॉइंटमेंट बुक करना है।"
  },
  {
    id: "tyre-change",
    title: "TYRE REPLACEMENT & FITTING",
    hindiTitle: "टायर चेंज और फिटिंग",
    image: "/tyre-change.png",
    desc: "पुराने या घिसे हुए टायरों को बदलकर नए टायरों की फिटिंग की जाती है। नए टायरों से गाड़ी की ग्रिप और सुरक्षा बहुत बेहतर हो जाती है।",
    features: [
      "पुराने टायरों को बदलना — ₹50 प्रति टायर",
      "नए टायर फिटमेंट और बीड सीटिंग",
      "वाल्व पिन रिप्लेसमेंट और लीक चेक",
      "टायर प्रेशर कैलिब्रेशन",
      "टायर रोटेशन असिस्टेंस"
    ],
    price: "₹50",
    waMessage: "नमस्ते MM Car Care! मुझे अपनी कार के टायर रिप्लेसमेंट / टायर चेंज सर्विस के लिए अपॉइंटमेंट चाहिए।"
  },
  {
    id: "jumpstart",
    title: "EMERGENCY JUMP START",
    hindiTitle: "जम्प स्टार्ट सर्विस",
    image: "/jump-start.png",
