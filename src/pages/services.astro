  },
  {
    id: "bodypaint",
    title: "DENTING, PAINTING & BODY REPAIR",
    hindiTitle: "डेंटिंग पेंटिंग और बॉडी रिपेयर",
    image: "/body-repair.png",
    desc: "कार पर लगे डेंट, स्क्रैच या रंग उतरने की समस्या को हम एक्सपर्ट डेंटिंग और पेंटिंग सर्विस से ठीक करते हैं। हम ऑटो-ग्रेड पेंट, clear coat और मैचिंग कलर टेक्नोलॉजी का उपयोग करके आपकी गाड़ी को शोरूम जैसी चमकदार फिनिश देते हैं।",
    features: [
      "पेंटलेस डेंट रिमूवल (PDR) टेक्नोलॉजी",
      "स्क्रैच रिमूवल और टच-अप पेंट",
      "कंप्यूटर जनरेटेड कलर मैचिंग",
      "फुल बॉडी रीपेंट और क्लियर कोट फिनिश",
      "बम्पर रिपेयर और प्लास्टिक वेल्डिंग"
    ],
