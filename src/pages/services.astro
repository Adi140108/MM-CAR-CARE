---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';

const title = "Our Services | MM Car Care - Auto Repair & Diagnostics";
const description = "MM Car Care के ऑटो मेंटेनेंस, एसी सर्विस, सिस्टम डायग्नोसिस, व्हील बैलेंसिंग, व्हील अलाइनमेंट और डेंटिंग पेंटिंग सेवाओं की पूरी सूची देखें। बुकिंग के लिए व्हाट्सएप पर क्लिक करें।";

const services = [
  {
    id: "maintenance",
    title: "ENGINE CAR SERVICE",
    hindiTitle: "कार सर्विस और मेंटेनेंस",
    image: "/car-service.png",
    desc: "हम इंजन की जाँच, ट्यूनिंग और मेंटेनेंस करके आपकी कार को बेहतर परफॉर्मेंस देते हैं। हमारे विशेषज्ञ मैकेनिक गाड़ी के हर यांत्रिक हिस्से की बारीकी से जांच करते हैं ताकि गाड़ी लंबी दूरी के सफर में भी बिना किसी रुकावट के बेहतरीन माइलेज और स्मूद ड्राइव दे।",
    features: [
      "इंजन ऑयल और फ़िल्टर चेंज (OEM/OES)",
      "स्पार्क प्लग क्लीनिंग और रिप्लेसमेंट",
      "कूलेंट और फ्लूइड लेवल चेक",
      "एयर फिल्टर और केबिन फिल्टर रिप्लेसमेंट",
      "सामान्य सुरक्षा और ब्रेक पॉइंट चेकअप"
    ],
    price: "₹2,500 से शुरू",
    waMessage: "नमस्ते MM Car Care! मैं अपनी कार के जनरल कार सर्विस / मेंटेनेंस वर्क की बुकिंग करना चाहता हूँ। कृपया मुझे समय साझा करें।"
  },
  {
    id: "foamwash",
    title: "PREMIUM FOAM WASH",
    hindiTitle: "कार फ़ोम वॉश",
    image: "/foam-wash.png",
    desc: "प्रेशर वॉशर, उच्च गुणवत्ता वाले कार शैम्पू और फ़ोम गन की मदद से गाड़ी की गहरी सफाई की जाती है। यह आपकी कार की चमक बनाए रखता है और बॉडी पेंट को सुरक्षित रखता है।",
    features: [
      "हाई-प्रेशर फ़ोम स्प्रे क्लीनिंग",
      "मैट और ग्लास क्लीनिंग",
      "इंटीरियर वैक्यूमिंग और डैशबोर्ड पॉलिश",
      "टायर और व्हील आर्च क्लीनिंग",
      "प्रीमियम लिक्विड वैक्स फिनिश"
    ],
    price: "₹250",
    waMessage: "नमस्ते MM Car Care! मैं अपनी गाड़ी के लिए प्रीमियम फ़ोम वॉश सर्विस बुक करना चाहता हूँ।"
  },
  {
    id: "ac",
    title: "AIR CONDITIONING SERVICES",
    hindiTitle: "एसी सर्विसिंग और कूलिंग रिपेयर",
    image: "/ac-service.png",
    desc: "कार के AC की सर्विस, गैस चार्ज और कूलिंग सुधार की सुविधा उपलब्ध है। गर्मियों में कार के केबिन को चिल्ड रखने के लिए हम कंप्रेसर चेक, लीक डिटेक्शन, कंडेनसर क्लीनिंग और प्रीमियम रेफ्रिजरेंट गैस रीफिल की पूरी सर्विस देते हैं।",
